# Build artifacts
build/
build-debug/
*.o
*.a
*.so
*.dylib

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json

# Data — large raw files don't belong in git
data/raw/
data/cache/

# Environment / secrets
.env
*.env

# macOS
.DS_Store

# Runtime
.cortex.log
.cortex.pid

# IDE
.vscode/
.idea/
.claude/
*.swp

# Terraform — never commit state (may contain secrets) or local vars
deploy/aws/terraform/.terraform/
deploy/aws/terraform/*.tfstate
deploy/aws/terraform/*.tfstate.*
deploy/aws/terraform/*.tfvars
!deploy/aws/terraform/*.tfvars.example
deploy/aws/terraform/.terraform.lock.hcl
