# Copy to .env and fill in. Never commit the real .env (it is git-ignored).

# Public hostname for the demo — your free DuckDNS subdomain.
# Example: cortex-nba.duckdns.org
DOMAIN=your-subdomain.duckdns.org

# Email for Let's Encrypt certificate expiry notices (any address you own).
ACME_EMAIL=you@example.com

# PostgreSQL password. Use a long random string, e.g. `openssl rand -hex 24`.
POSTGRES_PASSWORD=change-me-to-a-long-random-string
